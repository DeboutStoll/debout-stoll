# ============================================================================
# Debout, Stoll ! — environment variables
# Copy this file to `.env.local` for local dev, or set them in your host
# (Vercel → Project Settings → Environment Variables) for production.
#
# EVERY VARIABLE IS OPTIONAL: with none set, the app runs fully locally using
# a JSON file store and console-logged emails. Add them to switch on the real
# production backends.
# ============================================================================

# --- Public site URL (used for canonical, hreflang, OG, sitemap) ------------
# Production apex domain. No trailing slash. Must be https for HSTS + PWA.
NEXT_PUBLIC_SITE_URL=https://debout-stoll.com

# --- Database: Supabase (leave empty → local JSON store in /data) -----------
# Create a project at https://supabase.com, then run the SQL in DEPLOIEMENT.md.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket for moderated contribution uploads (default: contributions)
SUPABASE_BUCKET=contributions

# Starting offset for the live member counter (real members already gathered)
MEMBER_BASE_COUNT=0

# --- Transactional email: Resend (leave empty → emails logged to console) ---
# https://resend.com — verify your sending domain first.
RESEND_API_KEY=
EMAIL_FROM=Debout Stoll <contact@debout-stoll.com>
EMAIL_NOTIFY=contact@debout-stoll.com

# --- Anti-spam: Cloudflare Turnstile (leave empty → captcha skipped) --------
# https://developers.cloudflare.com/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analytics: Plausible (leave empty → no analytics, no cookies) ----------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Self-hosted Plausible? override the script URL:
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
